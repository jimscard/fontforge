<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: FontForge bundles Homebrew dylibs that are not Apple-signed -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required: Python's ctypes and some extensions need to map executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required: Python respects PYTHONPATH and DYLD env vars at startup -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
